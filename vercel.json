{
  "rewrites": [
    { "source": "/tilt", "destination": "/tilt.html" },
    { "source": "/gallery", "destination": "/gallery.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=*, gyroscope=*, magnetometer=*"
        }
      ]
    }
  ]
}
